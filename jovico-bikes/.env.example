# Jovico Bikes - Environment Variables
# Copy this to .env.local and fill in your values

# ─── Database (Hostinger MySQL) ────────────────────────────
DATABASE_URL="mysql://USERNAME:PASSWORD@HOST:3306/jovico_bikes"

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
SESSION_SECRET="your-session-secret-key-32chars!!"

# ─── Site ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Jovico Bikes"

# ─── Upload (local or Cloudinary) ─────────────────────────
UPLOAD_DIR="./public/uploads"
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ─── Email (optional — Nodemailer) ────────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="hello@jovicoworld.com"
# SMTP_PASS="your-app-password"
