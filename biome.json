{
    "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "a11y": {
                "useAltText": "warn",
                "useButtonType": "warn"
            },
            "complexity": {
                "noExcessiveCognitiveComplexity": "warn"
            },
            "correctness": {
                "noUnusedVariables": "warn",
                "noUnusedImports": "warn"
            },
            "style": {
                "noNonNullAssertion": "off",
                "useImportType": "warn"
            },
            "suspicious": {
                "noExplicitAny": "off"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "formatWithErrors": false,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "jsxQuoteStyle": "single",
            "quoteProperties": "asNeeded",
            "trailingCommas": "es5",
            "semicolons": "asNeeded",
            "arrowParentheses": "always",
            "bracketSameLine": false,
            "quoteStyle": "single",
            "attributePosition": "auto"
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        },
        "formatter": {
            "quoteStyle": "single"
        }
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!!.next/**",
            "!!node_modules/**",
            "!!prisma/generated/**",
            "!!prisma/migrations/**"
        ]
    }
}
